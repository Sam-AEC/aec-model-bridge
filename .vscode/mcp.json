{
  "servers": {
    "aec-model-bridge": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "revit_mcp_server.mcp_server"],
      "env": {
        "MCP_REVIT_MODE": "bridge",
        "MCP_REVIT_BRIDGE_URL": "http://127.0.0.1:3000",
        "MCP_REVIT_WORKSPACE_DIR": "${workspaceFolder}",
        "MCP_REVIT_ALLOWED_DIRECTORIES": "${workspaceFolder}"
      }
    }
  }
}
