<UserControl x:Class="RevitBridge.UI.BridgePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinWidth="360"
             MinHeight="420"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             FontFamily="Segoe UI">
    <Grid Background="#F8FAFC">
        <wv2:WebView2 x:Name="Browser" />

        <Border x:Name="Fallback"
                Visibility="Collapsed"
                Background="#F8FAFC"
                Padding="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="AEC Model Bridge"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="FallbackMessage"
                           Text="Panel runtime unavailable."
                           FontSize="13"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           Foreground="#4B5563" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
