      "Inputs": [
        {
          "Id": "7f7442ddd086491e879837b6b3aaed0f",
          "Name": "num_bays",
          "Description": "num_bays",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ce3c6a63b15943318571454d7838c07a",
          "Name": "bay_width",
          "Description": "bay_width",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ca97ceb06718439195f4b566208f494e",
          "Name": "num_floors",
          "Description": "num_floors",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "c2db1878954e4f36bf8c7ab3c31821ef",
          "Name": "floor_height",
          "Description": "floor_height",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "002929fe3b25431da7174d04d10a62d2",
          "Name": "area",
          "Description": "area = (num_bays * bay_width) * (num_floors * floor_height)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b9d2107fe2b84a3c8c06ca6556a980b1",
          "Name": "cost",
          "Description": "cost = area * 650",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "area = (num_bays * bay_width) * (num_floors * floor_height);\ncost = area * 650.0;"
